# ══════════════════════════════════════════════════
# Variables de entorno — clasificador-distribuido
# ══════════════════════════════════════════════════
# Copia este archivo como .env y rellena los valores.
# NUNCA subas .env al repositorio.

# ── FASE 4: Supabase ─────────────────────────────
# Obtener desde: https://supabase.com → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key-aqui

# ── FASE 7: IPs de la LAN ─────────────────────────
# Cambiar cuando el despliegue sea físico en las laptops
WORKER_1_URL=http://localhost:5001
WORKER_2_URL=http://localhost:5002
WORKER_3_URL=http://localhost:5003
MASTER_URL=http://localhost:8000

# ── Nodo actual (para worker/sync.py) ─────────────
# Cambiar en cada laptop worker: node1, node2 o node3
NODE_NAME=node1
NODE_STORAGE=../storage/node1
